{
  "manifest_version": 3,
  "name": "Axure原型同步助手",
  "version": "1.0.0",
  "description": "一键上传Axure预览原型到远程服务器并生成分享链接",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>",
    "file:///*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*/*", "file:///*"],
      "js": ["content/content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "popup/popup.html",
        "popup/popup.css",
        "popup/popup.js"
      ],
      "matches": ["*://*/*", "file:///*"]
    }
  ]
}
